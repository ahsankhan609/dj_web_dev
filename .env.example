SECRET_KEY=your-secret-key-here
DEBUG=True
DJ_ADMIN_USERNAME=admin-username
DJ_ADMIN_PASSWORD=admin-password

# Database configuration
# Default: sqlite3 (recommended for local learning)
DB_ENGINE=sqlite3

# MySQL settings (used only when DB_ENGINE=mysql)
# DB_NAME=your-database-name
# DB_USER=your-database-user
# DB_PASSWORD=your-database-password
# DB_HOST=127.0.0.1
# DB_PORT=3306